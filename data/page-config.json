useEffect(() => {
  // If a custom URL parameter is passed, use it; otherwise load the default/page config
  fetch(`${import.meta.env.BASE_URL}data/page-config.json`)
    .then(res => res.json())
    .then(data => {
      setNodes(data.nodes);
      setConnections(data.connections);
    })
    .catch(err => console.error("Error loading config:", err));
}, []);
